---
interface Props {
    title: string;
    excerpt: string;
    date?: string;
    image?: string;
    href?: string;
}

const { title, excerpt, date = "Reciente", image, href = "#" } = Astro.props;
---

<a href={href} class="group block h-full">
    <article
        class="h-full flex flex-col rounded-2xl bg-pantera-gray border border-white/10 overflow-hidden transition-all duration-300 hover:border-pantera-green/50 hover:shadow-lg hover:-translate-y-1"
    >
        {
            image && (
                <div class="h-48 overflow-hidden">
                    <img
                        src={image}
                        alt={title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    />
                </div>
            )
        }

        <div class="p-6 flex flex-col flex-grow">
            <span class="text-xs font-medium text-pantera-green mb-2"
                >{date}</span
            >
            <h3
                class="text-xl font-bold text-white mb-3 group-hover:text-pantera-green transition-colors"
            >
                {title}
            </h3>
            <p class="text-white/60 text-sm leading-relaxed flex-grow">
                {excerpt}
            </p>

            <div
                class="mt-4 flex items-center text-pantera-green text-sm font-medium opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0"
            >
                Leer más
                <svg
                    class="w-4 h-4 ml-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </div>
        </div>
    </article>
</a>
