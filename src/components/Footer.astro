---
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-pantera-black text-white">


  <!-- Top subtle divider -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 pt-20 pb-10">

    <!-- Main grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-14 mb-16">

      <!-- Brand -->
      <div class="text-center sm:text-left">
        <a href="/" class="inline-block mb-6">
          <img
            src="/logo.webp"
            alt="Escuela de basquetbol Panteras"
            class="mx-auto sm:mx-0 w-44 md:w-52 select-none
                   transition-all duration-500
                   hover:scale-105
                   hover:drop-shadow-[0_20px_35px_rgba(204,204,204,0.3)]"
            loading="lazy"
          />
        </a>

        <p class="text-white/60 text-sm leading-relaxed max-w-xs mx-auto sm:mx-0">
          Formamos atletas de alto rendimiento con valores, disciplina y pasión
          por el baloncesto.
        </p>

        <!-- Social -->
        <div class="mt-6 flex justify-center sm:justify-start gap-3">
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/people/Escuela-de-baloncesto-Panteras-Nicol%C3%A1s-Romero/100076881560047/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="group p-3 rounded-xl bg-white/5 border border-white/10
                  hover:bg-[#1877f2]/20 hover:border-[#1877f2]/40
                  transition-all duration-300 hover:scale-110"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 12a10 10 0 1 0-11.5 9.9v-7h-2v-3h2v-2.3c0-2 1.2-3.1 3-3.1.9 0 1.8.2 1.8.2v2h-1c-1 0-1.3.6-1.3 1.2V12h2.3l-.4 3h-1.9v7A10 10 0 0 0 22 12z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/panterasnicolasromero/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="group p-3 rounded-xl bg-white/5 border border-white/10
                  hover:bg-pink-500/20 hover:border-pink-400/40
                  transition-all duration-300 hover:scale-110"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <path d="M12 8.5a3.5 3.5 0 1 0 0 7a3.5 3.5 0 0 0 0-7z"/>
              <circle cx="17" cy="7" r="1"/>
            </svg>
          </a>
          <!-- YouTube -->
          <a
            href="https://www.youtube.com/@panterasnicolasromero5433"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube"
            class="group p-3 rounded-xl bg-white/5 border border-white/10
                  hover:bg-red-500/20 hover:border-red-500/40
                  transition-all duration-300 hover:scale-110"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21.8 8s-.2-1.5-.8-2.2c-.8-.9-1.7-.9-2.1-1C16.6 4.5 12 4.5 12 4.5s-4.6 0-6.9.3c-.4.1-1.3.1-2.1 1C2.4 6.5 2.2 8 2.2 8S2 9.6 2 11.3v1.4c0 1.7.2 3.3.2 3.3s.2 1.5.8 2.2c.8.9 1.9.8 2.4 1 1.7.2 7 .3 7 .3s4.6 0 6.9-.3c.4-.1 1.3-.1 2.1-1 .6-.7.8-2.2.8-2.2s.2-1.6.2-3.3v-1.4C22 9.6 21.8 8 21.8 8zM10 14.7V9.3l5.2 2.7z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Location -->
      <div>
        <h3 class="font-semibold text-white mb-4 tracking-wide">
          Ubicación
        </h3>
        <address class="not-italic space-y-2 text-white/60 text-sm leading-relaxed">
          <p>Cda. Las Rosas No. 19</p>
          <p>Col. Independencia, C.P. 54409</p>
          <p>Nicolás Romero, Estado de México</p>
        </address>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-semibold text-white mb-4 tracking-wide">
          Contacto
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href="https://wa.me/525528854621"
              target="_blank"
              class="text-white/60 hover:text-pantera-green transition"
            >
              WhatsApp: 55 2885 4621
            </a>
          </li>
          <li>
            <a
              href="mailto:panterasnicolasromero@gmail.com"
              class="text-white/60 hover:text-pantera-green transition break-all"
            >
              panterasnicolasromero@gmail.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-semibold text-white mb-4 tracking-wide">
          Navegación
        </h3>
        <ul class="space-y-3 text-sm text-white/60">
          <li><a href="/" class="hover:text-pantera-green transition">Inicio</a></li>
          <li><a href="/partidos" class="hover:text-pantera-green transition">Partidos</a></li>
          <li><a href="/noticias" class="hover:text-pantera-green transition">Noticias</a></li>
          <li><a href="/convocatorias" class="hover:text-pantera-green transition">Convocatorias</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-white/40">
      <p class="text-center md:text-left">
        © {currentYear} Escuela de Baloncesto Panteras. Todos los derechos reservados.
      </p>

      <a
        href="https://github.com/mmarcode"
        class="text-gray-500 hover:text-white ms-5 duration-300"
        target="_blank"
      >
        <svg
          class="h-4 w-4"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            fill-rule="evenodd"
            d="M10 .333A9.911 9.911 0 0 0 6.866 19.65c.5.092.678-.215.678-.477 0-.237-.01-1.017-.014-1.845-2.757.6-3.338-1.169-3.338-1.169a2.627 2.627 0 0 0-1.1-1.451c-.9-.615.07-.6.07-.6a2.084 2.084 0 0 1 1.518 1.021 2.11 2.11 0 0 0 2.884.823c.044-.503.268-.973.63-1.325-2.2-.25-4.516-1.1-4.516-4.9A3.832 3.832 0 0 1 4.7 7.068a3.56 3.56 0 0 1 .095-2.623s.832-.266 2.726 1.016a9.409 9.409 0 0 1 4.962 0c1.89-1.282 2.717-1.016 2.717-1.016.366.83.402 1.768.1 2.623a3.827 3.827 0 0 1 1.02 2.659c0 3.807-2.319 4.644-4.525 4.889a2.366 2.366 0 0 1 .673 1.834c0 1.326-.012 2.394-.012 2.72 0 .263.18.572.681.475A9.911 9.911 0 0 0 10 .333Z"
            clip-rule="evenodd">
          </path>
        </svg>
        <span class="sr-only">GitHub account</span>
      </a>
    </div>

  </div>
</footer>
