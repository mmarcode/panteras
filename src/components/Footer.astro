---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Logo from "@/assets/images/logo.webp";

const currentYear = new Date().getFullYear();

const navLinks = [
  { name: "Inicio", href: "#hero" },
  { name: "Partidos", href: "#partidos" },
  { name: "Noticias", href: "#noticias" },
  { name: "Convocatorias", href: "#convocatorias" },
  { name: "Reglamento", href: "#reglamento" },
];
---

<footer class="relative bg-pantera-black text-white">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent" />

  <div class="mx-auto max-w-7xl px-6 pt-20 pb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <div class="text-center sm:text-left">
        <a href="#hero" class="inline-block mb-6">
          <Image
            src={Logo}
            alt="Escuela de basquetbol Panteras"
            width={160}
            height={107}
            class="mx-auto sm:mx-0 select-none transition-all duration-500 hover:scale-105 hover:drop-shadow-[0_20px_35px_rgba(204,204,204,0.3)]"
            loading="lazy"
            decoding="async"
          />
        </a>

        <p class="text-white/60 text-sm leading-relaxed max-w-xs mx-auto sm:mx-0">
          Formamos atletas de alto rendimiento con valores, disciplina y pasión
          por el baloncesto.
        </p>

        <div class="mt-6 flex justify-center sm:justify-start gap-3">
          <a
            href="https://www.facebook.com/people/Escuela-de-baloncesto-Panteras-Nicol%C3%A1s-Romero/100076881560047/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="group p-3 rounded-xl bg-white/5 border border-white/10 hover:bg-[#1877f2]/20 hover:border-[#1877f2]/40 transition-all duration-300 hover:scale-110"
          >
            <Icon name="simple-icons:facebook" class="w-5 h-5" />
          </a>
          <a
            href="https://www.instagram.com/panterasnicolasromero/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="group p-3 rounded-xl bg-white/5 border border-white/10 hover:bg-pink-500/20 hover:border-pink-400/40 transition-all duration-300 hover:scale-110"
          >
            <Icon name="simple-icons:instagram" class="w-5 h-5" />
          </a>
          <a
            href="https://www.youtube.com/@panterasnicolasromero5433"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube"
            class="group p-3 rounded-xl bg-white/5 border border-white/10 hover:bg-red-500/20 hover:border-red-500/40 transition-all duration-300 hover:scale-110"
          >
            <Icon name="simple-icons:youtube" class="w-5 h-5" />
          </a>
        </div>
      </div>

      <div>
        <h3 class="font-semibold text-white mb-4 tracking-wide flex items-center gap-2">
          <Icon name="lucide:map-pin" class="w-4 h-4 text-pantera-green" />
          Ubicación
        </h3>
        <address class="not-italic space-y-2 text-white/60 text-sm leading-relaxed">
          <p>Cda. Las Rosas No. 19</p>
          <p>Col. Independencia, C.P. 54409</p>
          <p>Nicolás Romero, Estado de México</p>
        </address>
      </div>

      <div>
        <h3 class="font-semibold text-white mb-4 tracking-wide flex items-center gap-2">
          <Icon name="lucide:phone" class="w-4 h-4 text-pantera-green" />
          Contacto
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href="https://wa.me/525528854621"
              target="_blank"
              class="text-white/60 hover:text-pantera-green transition flex items-center gap-2"
            >
              <Icon name="lucide:phone" class="w-4 h-4" />
              55 2885 4621
            </a>
          </li>
          <li>
            <a
              href="mailto:panterasnicolasromero@gmail.com"
              class="text-white/60 hover:text-pantera-green transition flex items-center gap-2 break-all"
            >
              <Icon name="lucide:mail" class="w-4 h-4 shrink-0" />
              panterasnicolasromero@gmail.com
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-white mb-4 tracking-wide">
          Navegación
        </h3>
        <ul class="space-y-2 text-sm text-white/60">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="hover:text-pantera-green transition flex items-center gap-1.5 group"
              >
                <Icon name="lucide:chevron-right" class="w-3.5 h-3.5 text-pantera-green/0 group-hover:text-pantera-green transition-all" />
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-6 flex flex-col md:flex-row items-center justify-center gap-4 text-xs text-white/40">
      <p>
        © {currentYear} Escuela de Baloncesto Panteras. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
