---
import Button from "./Button.astro";
---

<section
    class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-20"
>
    <!-- Background with gradient and pattern -->
    <div class="absolute inset-0 bg-pantera-black">
        <div
            class="absolute inset-0 bg-gradient-radial from-pantera-gray to-pantera-black opacity-80"
        >
        </div>
        <div
            class="absolute inset-0 bg-[url('/assets/pattern.svg')] opacity-10 mix-blend-overlay"
        >
        </div>
        <!-- Decorative glow -->
        <div
            class="absolute top-1/4 left-1/4 w-96 h-96 bg-pantera-green/20 rounded-full blur-[128px]"
        >
        </div>
        <div
            class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-pantera-accent/10 rounded-full blur-[128px]"
        >
        </div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl px-6 text-center">
        <div class="animate-fade-in">
            <span
                class="inline-block py-1 px-3 rounded-full bg-white/5 border border-white/10 text-pantera-green text-sm font-medium mb-6 backdrop-blur-sm"
            >
                Escuela de Baloncesto
            </span>
            <h1
                class="text-6xl md:text-8xl font-extrabold tracking-tighter leading-tight mb-6"
            >
                <span class="block text-white">Pasión por el</span>
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-pantera-green to-pantera-accent drop-shadow-glow"
                >
                    Baloncesto
                </span>
            </h1>

            <p
                class="mt-6 text-xl text-white/70 max-w-2xl mx-auto leading-relaxed"
            >
                Formamos atletas completos con disciplina, técnica y valores. Únete a la familia Panteras.
            </p>

            <div
                class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center"
            >
                <Button
                    href="/convocatorias"
                    variant="primary"
                    class="w-full sm:w-auto"
                >
                    Inscríbete Ahora
                </Button>
                <Button
                    href="/partidos"
                    variant="secondary"
                    class="w-full sm:w-auto"
                >
                    Ver Partidos
                </Button>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div
        class="absolute bottom-14 left-1/2 -translate-x-1/2 animate-bounce text-white/30"
    >
        <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
    </div>
   <div
      class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-20 pointer-events-none"
    >
      <svg
        viewBox="0 0 1178 55.21875"
        preserveAspectRatio="none"
        class="w-full h-[60px] md:h-[80px]"
        xmlns="http://www.w3.org/2000/svg"
      >
        <polygon
          style="opacity:0.5;fill:#16181d;"
          points="0,0 1178,27.609375 0,55.21875"
        />
        <polygon
          style="fill:#15171c;"
          points="1178,0 1178,55.21875 0,55.21875"
        />
      </svg>
    </div>
</section>
