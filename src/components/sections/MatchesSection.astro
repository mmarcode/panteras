---
import Section from "../Section.astro";
import MatchCard from "../MatchCard.astro";
import Button from "../Button.astro";

const upcomingMatches = [
  {
    date: "12 Oct",
    time: "10:00 AM",
    category: "U-15 Varonil",
    rival: "Halcones",
    location: "Deportivo Nicolás Romero",
  },
  {
    date: "12 Oct",
    time: "12:00 PM",
    category: "U-17 Femenil",
    rival: "Lobos",
    location: "Deportivo Nicolás Romero",
  },
  {
    date: "13 Oct",
    time: "09:00 AM",
    category: "Mini Basket",
    rival: "Águilas",
    location: "Gimnasio Municipal",
  },
  {
    date: "13 Oct",
    time: "11:00 AM",
    category: "Pasarela",
    rival: "Toros",
    location: "Gimnasio Municipal",
  },
  {
    date: "19 Oct",
    time: "10:00 AM",
    category: "U-15 Varonil",
    rival: "Guerreros",
    location: "Deportivo Los Pinos",
  },
  {
    date: "19 Oct",
    time: "12:00 PM",
    category: "U-17 Femenil",
    rival: "Leones",
    location: "Deportivo Los Pinos",
  },
];
---

<Section id="partidos" class="bg-pantera-gray relative overflow-hidden px-0">
  <div class="relative z-10 mx-auto max-w-7xl px-6 py-16">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div>
        <span class="text-pantera-green font-bold tracking-wider uppercase text-sm">
          Próximos Encuentros
        </span>
        <h2 class="text-3xl md:text-4xl font-bold mt-2">
          Agenda Deportiva
        </h2>
        <p class="text-white/60 mt-2">
          Consulta los próximos encuentros de todas nuestras categorías. ¡Ven y apoya a las Panteras!
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {upcomingMatches.map((match) => <MatchCard {...match} />)}
    </div>
  </div>
</Section>
