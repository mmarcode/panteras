---
import { Monitor, Sun, Moon } from '@lucide/astro';
//import { useTranslations } from '@/i18n'
//import type { Lang } from '@/i18n'

interface Props {
  lang: string
  idSuffix: string
  className?: string
  showDropdown?: boolean
}

const { lang, idSuffix, className = '', showDropdown = false } = Astro.props
//const t = useTranslations(lang)

const baseButton =
  'flex w-9 h-9 items-center justify-center rounded-md text-hc-gray4 dark:text-hc-gray6 hover:bg-hc-gray3 dark:hover:bg-hc-gray3/15 transition-colors'
const optionClasses =
  'theme-option flex items-center gap-3 px-4 py-2 w-full text-left hover:bg-hc-green1 hover:text-hc-white transition-colors text-sm text-hc-gray2 dark:text-hc-white'
---

<div class="relative flex items-center">
  <button
    id={`darkToggle-${idSuffix}`}
    data-theme-toggle
    data-toggle-target={`theme-menu-${idSuffix}`}
    class={`${baseButton} ${className}`}
    aria-label="{t('menu.theme')}"
    aria-haspopup="menu"
    aria-expanded="false"
  >
    <span class="icon-light hidden">
      <Sun class="w-5 h-5" />
    </span>
    <span class="icon-dark hidden">
      <Moon class="w-5 h-5" />
    </span>
    <span class="icon-system">
      <Monitor class="w-5 h-5" />
    </span>
  </button>

  {
    showDropdown && (
      <div
        id={`theme-menu-${idSuffix}`}
        data-theme-menu
        role="menu"
        class="hidden absolute top-full left-0 md:left-auto md:right-0 mt-1 w-36 bg-white dark:bg-hc-black1 border border-hc-gray10 dark:border-hc-gray2 rounded-md shadow-lg overflow-hidden z-50"
      >
        <button role="menuitem" class={optionClasses} data-theme="system">
          <Monitor class="w-4 h-4" />
          menu.system
        </button>
        <button role="menuitem" class={optionClasses} data-theme="light">
          <Sun class="w-4 h-4" />
          menu.light
        </button>
        <button role="menuitem" class={optionClasses} data-theme="dark">
          <Moon class="w-4 h-4" />
          menu.dark
        </button>
      </div>
    )
  }
</div>
