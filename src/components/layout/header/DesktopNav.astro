---
import { Icon } from 'astro-icon/components'

const baseLink = 'px-4 py-2 rounded-md transition-colors flex items-center gap-1'
const activeLink = 'bg-hc-green1 text-hc-white'
const inactiveLink = 'hover:bg-panteras-gray3 dark:hover:bg-panteras-gray3/15'

const navItems = [
  { path: 'nosotros', label: 'Acerca de' },
  { path: 'partidos', label: 'Partidos' },
  { path: 'noticias', label: 'Noticias' },
  { path: 'convocatorias', label: 'Convocatorias' },
]
---

<nav aria-label="Main navigation">
  <ul
    class="hidden md:flex items-center gap-2 font-display text-sm text-hc-gray dark:text-hc-white"
  >
    {
      navItems.map((item) => {
        const active = false;//isActive(item.path)

        if (item.hasDropdown) {
          return (
            <li class="relative group">
              <span
                class={`${baseLink} ${active ? activeLink : inactiveLink} cursor-default`}
              >
                {item.label}
                <Icon
                  name="lucide:chevron-down"
                  class="w-4 h-4 ml-0.5 group-hover:rotate-180 transition-transform duration-200"
                />
              </span>
            </li>
          )
        }

        return (
          <li>
            <a
              href="/"
              aria-current={active ? 'page' : undefined}
              class={`${baseLink} ${active ? activeLink : inactiveLink}`}
            >
              {item.label}
            </a>
          </li>
        )
      })
    }
  </ul>
</nav>
