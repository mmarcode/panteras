---
import { Image } from "astro:assets";
import Logo from "@/assets/images/logo.webp";
import Button from "./Button.astro";

const navItems = [
    { name: "Partidos", href: "/partidos" },
    { name: "Noticias", href: "/noticias" },
    { name: "Convocatorias", href: "/convocatorias" },
];
---

<header
    class="fixed top-0 w-full z-50 transition-all duration-300"
    id="main-header"
>
    <div
        class="absolute inset-0 bg-pantera-black/80 backdrop-blur-md border-b border-white/10"
    >
    </div>

    <nav
        class="relative max-w-7xl mx-auto px-6 h-20 flex items-center justify-between"
    >
        <a
            href="/"
            class="text-2xl font-extrabold tracking-wide text-pantera-green z-50"
        >
          <img
            src="../assets/images/logo.webp"
           
            alt="Escuela de basquetbol Panteras"
            class="select-none group-hover:drop-shadow-md drop-shadow-2xl hover:scale-110 hover:drop-shadow-[0_20px_35px_rgba(204,204,204,0.3)] transition-all duration-500"
            loading="lazy"
          />
        </a>

        <!-- Desktop Menu -->
        <ul class="hidden md:flex gap-8 items-center">
            {
                navItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            class="text__glowing text-sm font-medium text-white/80 hover:text-pantera-green transition-colors duration-300 relative group"
                        >
                            {item.name}
                        </a>
                    </li>
                ))
            }
            <!--
              {item.name}
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-pantera-green transition-all duration-300 group-hover:w-full" />
             -->
            <!-- <li>
                <Button
                    href="/convocatorias"
                    variant="primary"
                    class="!px-6 !py-2 text-sm"
                >
                    Unirse
                </Button>
            </li>-->
        </ul>

        <!-- Mobile Menu Button -->
        <button
            id="menu-toggle"
            class="md:hidden z-50 text-white focus:outline-none"
            aria-label="Toggle menu"
        >
            <svg
                class="w-8 h-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>

        <!-- Mobile Menu Overlay -->
        <div
            id="mobile-menu"
            class="fixed inset-0 bg-pantera-black/95 backdrop-blur-xl z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
        >
            <ul class="flex flex-col gap-8 text-center">
                {
                    navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class="text-2xl font-bold text-white hover:text-pantera-green transition-colors"
                            >
                                {item.name}
                            </a>
                        </li>
                    ))
                }
                <li class="mt-4">
                    <Button href="/convocatorias" variant="primary">
                        Unirse al equipo
                    </Button>
                </li>
            </ul>
        </div>
    </nav>
</header>

<script>
    const header = document.getElementById("main-header");
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuLinks = mobileMenu?.querySelectorAll("a");

    // Scroll effect
    window.addEventListener("scroll", () => {
        if (window.scrollY > 50) {
            header?.classList.add("shadow-glass");
        } else {
            header?.classList.remove("shadow-glass");
        }
    });

    // Mobile menu toggle
    menuToggle?.addEventListener("click", () => {
        const isOpen = mobileMenu?.classList.contains("opacity-0");

        if (isOpen) {
            mobileMenu?.classList.remove("opacity-0", "pointer-events-none");
            document.body.style.overflow = "hidden";
            menuToggle.innerHTML = `
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      `;
        } else {
            mobileMenu?.classList.add("opacity-0", "pointer-events-none");
            document.body.style.overflow = "";
            menuToggle.innerHTML = `
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      `;
        }
    });

    // Close menu on link click
    menuLinks?.forEach((link) => {
        link.addEventListener("click", () => {
            mobileMenu?.classList.add("opacity-0", "pointer-events-none");
            document.body.style.overflow = "";
            if (menuToggle) {
                menuToggle.innerHTML = `
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        `;
            }
        });
    });
</script>

<style>
  .text__glowing {
    transition: text-shadow 0.3s ease;
  }

  .text__glowing:hover {
    text-shadow:
    2px 2px 20px #fff;
  }
</style>
