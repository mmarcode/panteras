---
import Button from "./Button.astro";

const navItems = [
  { name: "Inicio", href: "#hero" },
  { name: "Partidos", href: "#partidos" },
  { name: "Noticias", href: "#noticias" },
  { name: "Convocatorias", href: "#convocatorias" },
  { name: "Reglamento", href: "#reglamento" },
];
---

<header
  class="fixed top-0 w-full z-50 transition-all duration-300"
  id="main-header"
>
  <div class="absolute inset-0 bg-pantera-black/60 backdrop-blur-md border-b border-white/5" />

  <nav class="relative max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
    <ul class="flex items-center gap-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-sm font-medium text-white/70 hover:text-pantera-green transition-colors duration-300"
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/mmarcode"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="flex items-center justify-center w-9 h-9 rounded-full text-white/50 hover:text-white hover:bg-white/5 transition-all duration-300"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.338c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
      </a>

      <button
        id="menu-toggle"
        class="md:hidden z-50 text-white/70 hover:text-white focus:outline-none"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div
      id="mobile-menu"
      class="fixed inset-0 bg-pantera-black/95 backdrop-blur-xl z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
    >
      <ul class="flex flex-col gap-8 text-center">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-2xl font-bold text-white hover:text-pantera-green transition-colors"
            >
              {item.name}
            </a>
          </li>
        ))}
        <li class="mt-4">
          <Button href="#convocatorias" variant="primary">
            Unirse al equipo
          </Button>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById("main-header");
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuLinks = mobileMenu?.querySelectorAll("a");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("shadow-glass");
    } else {
      header?.classList.remove("shadow-glass");
    }
  });

  menuToggle?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.contains("opacity-0");

    if (isOpen) {
      mobileMenu?.classList.remove("opacity-0", "pointer-events-none");
      document.body.style.overflow = "hidden";
      menuToggle.innerHTML = `
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      `;
    } else {
      mobileMenu?.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
      menuToggle.innerHTML = `
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      `;
    }
  });

  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
      if (menuToggle) {
        menuToggle.innerHTML = `
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        `;
      }
    });
  });
</script>
