---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Section from "../components/Section.astro";
import NewsCard from "../components/NewsCard.astro";

const news = [
    {
        title: "Inicia la temporada 2026",
        excerpt:
            "Nuestros equipos están listos para enfrentar los nuevos retos de la liga estatal. Conoce el calendario y apoya a tu equipo.",
        date: "10 Oct 2026",
        image: "https://images.unsplash.com/photo-1546519638-68e109498ffc?auto=format&fit=crop&q=80&w=800",
    },
    {
        title: "Convocatoria abierta",
        excerpt:
            "Buscamos nuevos talentos para nuestras categorías juveniles. ¡Asiste a las pruebas este fin de semana en el deportivo!",
        date: "05 Oct 2026",
        image: "https://images.unsplash.com/photo-1519861531473-920026393112?auto=format&fit=crop&q=80&w=800",
    },
    {
        title: "Campeones Regionales",
        excerpt:
            "La categoría U-13 se corona campeona en el torneo regional de verano tras una final cardíaca.",
        date: "28 Sep 2026",
        image: "https://images.unsplash.com/photo-1518407613690-d9fc990e795f?auto=format&fit=crop&q=80&w=800",
    },
    {
        title: "Clínica de Tiro",
        excerpt:
            "Mejora tu técnica de tiro con nuestro taller intensivo impartido por entrenadores profesionales.",
        date: "15 Sep 2026",
        image: "https://images.unsplash.com/photo-1574623452334-1e0ac2b3ccb4?auto=format&fit=crop&q=80&w=800",
    },
    {
        title: "Nuevo Uniforme",
        excerpt:
            "Presentamos la nueva piel de las Panteras para la temporada 2026. ¡Adquiérelo ya!",
        date: "01 Sep 2026",
        image: "https://images.unsplash.com/photo-1515523110800-9415d13b84a8?auto=format&fit=crop&q=80&w=800",
    },
    {
        title: "Visita de Jugadores Pro",
        excerpt:
            "Jugadores de la liga profesional visitaron nuestra academia para convivir con los niños.",
        date: "20 Ago 2026",
        image: "https://images.unsplash.com/photo-1504450758481-7338eba7524a?auto=format&fit=crop&q=80&w=800",
    },
];
---

<Layout title="Noticias | Panteras">
    <Header />

    <Section class="pt-32 pb-10">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 text-center">
            Últimas <span class="text-pantera-green">Noticias</span>
        </h1>
        <p class="text-white/60 text-center max-w-2xl mx-auto text-lg mb-12">
            Entérate de todo lo que sucede en la comunidad Panteras.
        </p>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {news.map((item) => <NewsCard {...item} />)}
        </div>
    </Section>
</Layout>
