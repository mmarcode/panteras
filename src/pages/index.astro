---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import MatchCard from "../components/MatchCard.astro";
import NewsCard from "../components/NewsCard.astro";
import Button from "../components/Button.astro";

const upcomingMatches = [
    {
        date: "12 Oct",
        time: "10:00 AM",
        category: "U-15 Varonil",
        rival: "Halcones",
        location: "Deportivo Nicolás Romero",
    },
    {
        date: "12 Oct",
        time: "12:00 PM",
        category: "U-17 Femenil",
        rival: "Lobos",
        location: "Deportivo Nicolás Romero",
    },
    {
        date: "13 Oct",
        time: "09:00 AM",
        category: "Mini Basket",
        rival: "Águilas",
        location: "Gimnasio Municipal",
    },
];

const latestNews = [
    {
        title: "Inicia la temporada 2026",
        excerpt:
            "Nuestros equipos están listos para enfrentar los nuevos retos de la liga estatal.",
        date: "10 Oct 2026",
    },
    {
        title: "Convocatoria abierta",
        excerpt:
            "Buscamos nuevos talentos para nuestras categorías juveniles. ¡Asiste a las pruebas!",
        date: "05 Oct 2026",
    },
    {
        title: "Campeones Regionales",
        excerpt:
            "La categoría U-13 se corona campeona en el torneo regional de verano.",
        date: "28 Sep 2026",
    },
];
---

<MainLayout title="Panteras Basket | Escuela de Baloncesto">
  <!---<Header />--->
  <Hero />

  <!-- Values Section -->
  <Section class="bg-pantera-black">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">
        Más que un equipo, <span class="text-pantera-green"
            >una familia</span
        >
      </h2>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        En Panteras no solo enseñamos a jugar baloncesto, formamos
        personas con valores que trascienden la cancha.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        [
          {
            title: "Disciplina",
            desc: "Constancia y esfuerzo en cada entrenamiento para alcanzar la excelencia.",
          },
          {
            title: "Trabajo en Equipo",
            desc: "Aprendemos a confiar en nuestros compañeros y a jugar unidos.",
          },
          {
            title: "Pasión",
            desc: "Vivimos el baloncesto con intensidad y amor por el deporte.",
          },
        ].map((value) => (
          <div class="p-8 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 transition duration-300 text-center group">
            <div class="w-16 h-16 mx-auto bg-pantera-green/20 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg
                class="w-8 h-8 text-pantera-green"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">
              {value.title}
            </h3>
            <p class="text-white/60">{value.desc}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Matches Section -->
 <Section class="bg-pantera-gray relative overflow-hidden px-0">
  <!-- Contenido centrado -->
  <div class="relative z-10 mx-auto max-w-7xl px-6 py-16">

    <div
      class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6"
    >
      <div>
        <span class="text-pantera-green font-bold tracking-wider uppercase text-sm">
          Próximos Encuentros
        </span>
        <h2 class="text-3xl md:text-4xl font-bold mt-2">
          Agenda Deportiva
        </h2>
      </div>

      <Button href="/partidos" variant="outline">
        Ver calendario completo
      </Button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {upcomingMatches.map((match) => <MatchCard {...match} />)}
    </div>

  </div>
</Section>



  <!-- News Section -->
  <Section>
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Últimas Noticias
      </h2>
      <p class="text-white/60">
        Mantente al día con lo que sucede en nuestra academia.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {latestNews.map((news) => <NewsCard {...news} />)}
    </div>

    <div class="text-center mt-12">
      <Button href="/noticias" variant="secondary"
        >Leer todas las noticias</Button
      >
    </div>
  </Section>

  <!-- CTA Section -->
  <Section class="bg-pantera-green text-pantera-black text-center !py-24">
    <h2 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight">
      ¿Listo para jugar?
    </h2>
    <p
      class="text-pantera-black/80 text-xl max-w-2xl mx-auto mb-10 font-medium"
    >
      Únete a Panteras y comienza tu camino en el baloncesto.
      Entrenamientos para todas las edades y niveles.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/convocatorias"
        class="inline-flex items-center justify-center rounded-full px-8 py-4 bg-black text-white font-bold hover:bg-black/80 transition shadow-lg hover:-translate-y-1"
      >
        Inscribirme ahora
      </a>
      <a
        href="https://wa.me/1234567890"
        target="_blank"
        class="inline-flex items-center justify-center rounded-full px-8 py-4 bg-transparent border-2 border-black text-black font-bold hover:bg-black/10 transition"
      >
        Contactar por WhatsApp
      </a>
    </div>
  </Section>
</MainLayout>
