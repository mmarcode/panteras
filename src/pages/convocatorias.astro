---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
---

<MainLayout title="Convocatorias | Panteras">
    <Header />

    <Section class="pt-32">
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-6xl font-extrabold mb-6">
                Únete a las <span class="text-pantera-green">Panteras</span>
            </h1>
            <p class="text-white/60 max-w-2xl mx-auto text-lg">
                Buscamos nuevos talentos para formar parte de nuestros equipos
                representativos. ¡Demuestra tu pasión por el baloncesto!
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="space-y-8">
                <div
                    class="bg-pantera-gray p-8 rounded-3xl border border-white/10"
                >
                    <h3 class="text-2xl font-bold text-white mb-4">
                        Categorías Abiertas
                    </h3>
                    <ul class="space-y-4">
                        <li
                            class="flex justify-between items-center border-b border-white/10 pb-2"
                        >
                            <span class="text-white/80"
                                >Mini Basket (6-11 años)</span
                            >
                            <span class="text-pantera-green font-bold"
                                >Lun/Mie/Vie</span
                            >
                        </li>
                        <li
                            class="flex justify-between items-center border-b border-white/10 pb-2"
                        >
                            <span class="text-white/80"
                                >Pasarela (12-14 años)</span
                            >
                            <span class="text-pantera-green font-bold"
                                >Mar/Jue/Sab</span
                            >
                        </li>
                        <li
                            class="flex justify-between items-center border-b border-white/10 pb-2"
                        >
                            <span class="text-white/80"
                                >Cadetes (15-17 años)</span
                            >
                            <span class="text-pantera-green font-bold"
                                >Lun-Vie</span
                            >
                        </li>
                        <li class="flex justify-between items-center">
                            <span class="text-white/80">Elite (18+ años)</span>
                            <span class="text-pantera-green font-bold"
                                >Mar/Jue</span
                            >
                        </li>
                    </ul>
                </div>

                <div
                    class="bg-pantera-green/10 p-8 rounded-3xl border border-pantera-green/20"
                >
                    <h3 class="text-2xl font-bold text-pantera-green mb-4">
                        Requisitos
                    </h3>
                    <ul class="list-disc pl-5 space-y-2 text-white/80">
                        <li>
                            Ropa deportiva adecuada (short, playera, tenis de
                            baloncesto)
                        </li>
                        <li>Hidratación propia</li>
                        <li>Copia de acta de nacimiento</li>
                        <li>Certificado médico vigente</li>
                        <li>Muchas ganas de aprender</li>
                    </ul>
                </div>
            </div>

            <div class="bg-pantera-gray p-8 rounded-3xl border border-white/10">
                <h3 class="text-2xl font-bold text-white mb-6">Pre-Registro</h3>
                <form class="space-y-6">
                    <div>
                        <label
                            class="block text-sm font-medium text-white/60 mb-2"
                            >Nombre Completo</label
                        >
                        <input
                            type="text"
                            class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-pantera-green transition"
                            placeholder="Tu nombre"
                        />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label
                                class="block text-sm font-medium text-white/60 mb-2"
                                >Edad</label
                            >
                            <input
                                type="number"
                                class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-pantera-green transition"
                                placeholder="Años"
                            />
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-white/60 mb-2"
                                >Teléfono</label
                            >
                            <input
                                type="tel"
                                class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-pantera-green transition"
                                placeholder="55..."
                            />
                        </div>
                    </div>

                    <div>
                        <label
                            class="block text-sm font-medium text-white/60 mb-2"
                            >Categoría de interés</label
                        >
                        <select
                            class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-pantera-green transition"
                        >
                            <option>Mini Basket</option>
                            <option>Pasarela</option>
                            <option>Cadetes</option>
                            <option>Elite</option>
                        </select>
                    </div>

                    <div>
                        <label
                            class="block text-sm font-medium text-white/60 mb-2"
                            >Mensaje (Opcional)</label
                        >
                        <textarea
                            class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-pantera-green transition h-32"
                            placeholder="¿Tienes alguna duda?"></textarea>
                    </div>

                    <Button type="submit" variant="primary" class="w-full">
                        Enviar Registro
                    </Button>
                </form>
            </div>
        </div>
    </Section>
</MainLayout>
