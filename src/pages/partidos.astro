---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import MatchCard from "../components/MatchCard.astro";
import Section from "../components/Section.astro";

const matches = [
    {
        date: "Sábado 21 Sept",
        time: "10:00 AM",
        category: "U-15 Varonil",
        rival: "Halcones",
        location: "Unidad Deportiva Nicolás Romero",
    },
    {
        date: "Sábado 21 Sept",
        time: "12:00 PM",
        category: "U-17 Femenil",
        rival: "Lobos",
        location: "Unidad Deportiva Nicolás Romero",
    },
    {
        date: "Domingo 22 Sept",
        time: "09:00 AM",
        category: "Mini Basket",
        rival: "Águilas",
        location: "Gimnasio Municipal",
    },
    {
        date: "Domingo 22 Sept",
        time: "11:00 AM",
        category: "Pasarela",
        rival: "Toros",
        location: "Gimnasio Municipal",
    },
    {
        date: "Sábado 28 Sept",
        time: "10:00 AM",
        category: "U-15 Varonil",
        rival: "Guerreros",
        location: "Deportivo Los Pinos",
    },
    {
        date: "Sábado 28 Sept",
        time: "12:00 PM",
        category: "U-17 Femenil",
        rival: "Leones",
        location: "Deportivo Los Pinos",
    },
];
---

<Layout title="Partidos | Panteras">
    <Header />

    <Section class="pt-32 pb-10">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 text-center">
            Calendario de <span class="text-pantera-green">Juegos</span>
        </h1>
        <p class="text-white/60 text-center max-w-2xl mx-auto text-lg mb-12">
            Consulta los próximos encuentros de todas nuestras categorías. ¡Ven
            y apoya a las Panteras!
        </p>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {matches.map((match) => <MatchCard {...match} />)}
        </div>
    </Section>
</Layout>
